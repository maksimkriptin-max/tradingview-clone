{
  "name": "tradingview-clone",
  "version": "1.0.0",
  "description": "My TradingView Clone",
  "main": "index.html",
  "scripts": {
    "build": "npm run build:html && npm run build:css",
    "build:html": "npx html-minifier --collapse-if-empty --remove-comments --remove-redundant-attributes --remove-tag-whitespace",
    "build:css": "node_modules/.bin/gh-pages -d build -b gh-pages",
    "deploy": "gh-pages -d build"
  },
  "devDependencies": {
    "html-minifier": "^6.0.0",
    "gh-pages": "^3.2.1"
  }
}
